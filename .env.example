# Omit or set to `true` (default): middleware respects Supabase settings.maintenance_mode.
# Set to `false` on Vercel to always serve the live site (emergency override).
# MAINTENANCE_GATE_ENABLED=false

# Telegram support (floating bubble + /support → redirect). Optional full URL:
# NEXT_PUBLIC_SUPPORT_TELEGRAM_URL=https://t.me/YourBotUsername
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=Honeyywell_bot
