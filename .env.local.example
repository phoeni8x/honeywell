NEXT_PUBLIC_SUPABASE_URL=https://lzawlahzaabqvprrcomg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Used by serverless routes (e.g. push notifications) to build absolute URLs.
NEXT_PUBLIC_APP_URL=https://www.teamruby.net
# Split bots (recommended): admin = order alerts + /broadcast /kick commands; customer = /start, verify, customer DMs.
# If only TELEGRAM_BOT_TOKEN is set, it is used for both roles (single-bot mode).
TELEGRAM_ADMIN_BOT_TOKEN=
TELEGRAM_CUSTOMER_BOT_TOKEN=
# Legacy single token (used when the role-specific token above is unset):
TELEGRAM_BOT_TOKEN=
# Optional order alert destination (numeric chat id). If empty, ADMIN_TELEGRAM_USER_ID is used.
TELEGRAM_ORDER_CHAT_ID=
# Webhook secrets (setWebhook secret_token per bot). Falls back to TELEGRAM_WEBHOOK_SECRET if unset.
TELEGRAM_ADMIN_WEBHOOK_SECRET=
TELEGRAM_CUSTOMER_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_SECRET=
# Shown in team verification UI (no secret).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=Honeyywell_bot
# Supergroup/channel ID (negative, e.g. -100…). Members here = team members in the app.
# Private team channel (supergroup). Bot must be admin. Example:
TELEGRAM_CHANNEL_ID=-1002617245442
# Optional. If set, this Telegram user id skips channel check (resolved via getChat @username).
# Required for /broadcast in Telegram bot (numeric user id).
ADMIN_TELEGRAM_USER_ID=8061460870
NEXT_PUBLIC_SHOP_ADDRESS=
# Admin: obscured URL only. Middleware signs in as this Supabase user so the dashboard + /api/admin/* routes work.
ADMIN_EMAIL=rubyrobins444@gmail.com
ADMIN_PASSWORD=

# Web Push (Part 6) — generate keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=team@example.com
# Optional: protect POST /api/push/send for server-to-server (order status, etc.)
INTERNAL_PUSH_SECRET=

# Optional. If set, POST /api/customer/seed-demo requires header x-demo-seed-key or body.demo_seed_key to match.
# Use /account/seed-demo to create two demo orders + two demo tickets for the current browser token.
CUSTOMER_DEMO_SEED_KEY=

# Part 2 — optional until enabled
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ETHERSCAN_API_KEY=
CRYPTO_WALLET_ADDRESS=
# Fallback if not set in Supabase admin settings: bitcoin | ethereum | tether | litecoin | solana
ACTIVE_CRYPTO_COIN=ethereum
NEXT_PUBLIC_ACTIVE_CRYPTO_COIN=ethereum
COINGECKO_API_KEY=

# Dead-drop admin media: Cloudinary (optional). Server upload uses all three; for faster iPhone → Cloudinary
# (skips Vercel buffering), add an UNSIGNED upload preset in the Cloudinary console (folder e.g. dead-drops)
# and set CLOUDINARY_UPLOAD_PRESET_DEAD_DROPS to its name. Preset should allow image + video as needed.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET_DEAD_DROPS=
